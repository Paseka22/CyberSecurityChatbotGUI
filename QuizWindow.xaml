<Window x:Class="CyberSecurityChatbotGUI.QuizWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cyber Security Quiz"
        Height="450"
        Width="700">

    <Grid Margin="20">

        <StackPanel>

            <TextBlock
                x:Name="QuestionText"
                FontSize="22"
                FontWeight="Bold"
                TextWrapping="Wrap"
                Margin="0,0,0,20"/>

            <ListBox
                x:Name="OptionsListBox"
                Height="180"
                FontSize="18"/>

            <Button
                x:Name="NextButton"
                Content="Next"
                Width="150"
                Height="40"
                HorizontalAlignment="Center"
                Margin="0,20,0,0"
                Click="NextButton_Click"/>

        </StackPanel>

    </Grid>
</Window>