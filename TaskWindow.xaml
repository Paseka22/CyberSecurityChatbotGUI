<Window x:Class="CyberSecurityChatbotGUI.TaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Task Window"
        Height="450"
        Width="800">

    <Grid Margin="10">

        <!-- ========================= -->
        <!-- Task Management Interface -->
        <!-- ========================= -->

        <!-- Window title -->
        <TextBlock Text="Task Assistant"
                   FontSize="24"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,20"/>

        <!-- Textbox where the user enters a new task -->
        <TextBox x:Name="TaskDescriptionBox"
                 Width="350"
                 Height="30"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Top"
                 Margin="0,60,0,0"/>

        <!-- Button used to add a task -->
        <Button x:Name="AddTaskButton"
                Content="Add Task"
                Width="120"
                Height="35"
                HorizontalAlignment="Center"
                Margin="0,110,0,0"
                Click="AddTaskButton_Click"/>

        <!-- Displays all saved tasks -->
        <ListBox x:Name="TaskListBox"
                 Margin="20,170,20,20"/>

        <!-- Marks the selected task as completed -->
        <Button x:Name="MarkCompleteButton"
        Content="Mark Complete"
        Width="140"
        Height="35"
        HorizontalAlignment="Left"
        VerticalAlignment="Bottom"
        Margin="20,0,0,20"
        Click="MarkCompleteButton_Click"/>

        <!-- Deletes the selected task -->
        <Button x:Name="DeleteTaskButton"
        Content="Delete Task"
        Width="140"
        Height="35"
        HorizontalAlignment="Right"
        VerticalAlignment="Bottom"
        Margin="0,0,20,20"
        Click="DeleteTaskButton_Click"/>

    </Grid>

</Window>